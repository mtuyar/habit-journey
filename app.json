{
  "expo": {
    "name": "Alışkanlık Yolculuğum",
    "slug": "habit-journey",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icons/ios/icon-1024x1024.png",
    "scheme": "habitjourney",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mtuyarr.habitjourney",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B3D20",
        "foregroundImage": "./assets/images/app-icons/android/mipmap-xxxhdpi/ic_launcher.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mtuyarr.habitjourney"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-icons/favicon/favicon-32x32.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icons/ios/icon-1024x1024.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#FDFBF7",
          "dark": {
            "backgroundColor": "#FDFBF7"
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ad01e338-d3ad-4eec-9038-71519db52cad"
      }
    },
    "notification": {
      "icon": "./assets/images/android-icon-monochrome.png",
      "color": "#0B3D20"
    }
  }
}
